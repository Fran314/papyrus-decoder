# Assumes user "admin" and the project at /home/admin/papyrus-decoder.
# Edit User/WorkingDirectory/ExecStart if your setup differs.
[Unit]
Description=Papyrus decoder
After=network.target

[Service]
User=admin
WorkingDirectory=/home/admin/papyrus-decoder
ExecStart=/home/admin/papyrus-decoder/.venv/bin/python app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
